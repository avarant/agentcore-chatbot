# =============================================================================
# Agent77 — Terraform Variables
# Copy this file to terraform.tfvars and fill in your values.
# =============================================================================

aws_region   = "us-east-1"
project_name = "agent77"
environment  = "prod"

# Optional: Custom domain (requires ACM certificate in us-east-1)
# domain              = "chat.example.com"
# acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Agent Docker image URI — set after pushing to ECR
# agent_image_uri = "123456789012.dkr.ecr.us-east-1.amazonaws.com/agent77-agent:latest"

# Lambda configuration
lambda_memory_size = 512
lambda_timeout     = 30

# DynamoDB billing mode: PAY_PER_REQUEST or PROVISIONED
dynamodb_billing_mode = "PAY_PER_REQUEST"

# Cognito hosted UI domain prefix (must be globally unique)
# cognito_domain_prefix = "agent77-mycompany"

# Enable AgentCore runtime provisioning (requires Bedrock access)
enable_agentcore = true

# Foundation model for AgentCore
# agentcore_model_id = "anthropic.claude-3-sonnet-20240229-v1:0"

# CloudFront price class (PriceClass_100 = US/EU only, PriceClass_All = global)
cloudfront_price_class = "PriceClass_100"
