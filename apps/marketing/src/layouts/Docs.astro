---
import Base from './Base.astro';

interface Props {
  title?: string;
}

const { title = 'Agent77 Docs' } = Astro.props;
---

<Base title={title}>
  <div class="mx-auto flex max-w-6xl">
    <aside class="hidden w-64 shrink-0 border-r border-gray-200 bg-gray-50 px-6 py-10 md:block">
      <h2 class="text-sm font-semibold text-gray-900">Agent77 Docs</h2>
      <nav class="mt-6 space-y-2">
        <a href="/docs" class="block text-sm text-gray-600 hover:text-gray-900">Getting Started</a>
        <a href="/docs/token-endpoint" class="block text-sm text-gray-600 hover:text-gray-900">Token Endpoint</a>
        <a href="/docs/oidc-discovery" class="block text-sm text-gray-600 hover:text-gray-900">OIDC Discovery</a>
        <a href="/docs/mcp-server" class="block text-sm text-gray-600 hover:text-gray-900">MCP Server</a>
        <a href="/docs/snippet" class="block text-sm text-gray-600 hover:text-gray-900">JS Snippet</a>
      </nav>
    </aside>
    <main class="min-w-0 flex-1 px-8 py-10">
      <slot />
    </main>
  </div>
</Base>
